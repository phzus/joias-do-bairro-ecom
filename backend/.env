# ====================================================
#  Joias do Bairro — Backend (.env para desenvolvimento local)
#  Copie este arquivo para .env e preencha os valores
# ====================================================

# --- Banco de dados (PostgreSQL) ---
DATABASE_URL=postgres://medusa:senha_aqui@localhost:5432/medusa

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379

# --- Segredos (gere valores aleatórios de 64 chars) ---
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_64_CHARS
COOKIE_SECRET=TROQUE_POR_OUTRO_SEGREDO_FORTE_64_CHARS

# --- CORS ---
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:9000,http://localhost:3000,http://localhost:7001

# --- URL do backend ---
BACKEND_URL=http://localhost:9000

# --- Stripe (payment provider) ---
STRIPE_API_KEY=sk_test_SUBSTITUA_PELA_SUA_CHAVE

# --- SuperFrete (frete) ---
SUPERFRETE_CONTACT_EMAIL=contato@joiasdodobairro.com.br
SUPERFRETE_TOKEN=                  # Bearer token da conta SuperFrete
SUPERFRETE_ENV=sandbox             # sandbox | production
SUPERFRETE_FROM_CEP=               # CEP de origem da loja
SUPERFRETE_WEBHOOK_SECRET=         # Secret retornado ao registrar o webhook

# --- File Storage (S3 — deixar vazio para usar provider local) ---
S3_FILE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET=
S3_ENDPOINT=
